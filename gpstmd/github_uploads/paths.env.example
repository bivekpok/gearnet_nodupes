# Copy to paths.env, fill in your machine, then:
#   set -a && source paths.env && set +a
#   sbatch gnet_all_prod.sh

# Base directory (nested splits + default model output live under here)
export WORK_COVER="/path/to/foldseek_train/whole_test_cover"

# PDB roots (membrane + soluble folders)
export GEARNET_PDB_ROOT="/path/to/gearnet_files"
# Or set explicitly:
# export PDB_DIR="/path/to/pdb_m15_ac"
# export SOLUBLE_DIR="/path/to/watersoluble_proteins_ac"

# Optional overrides (defaults are derived from WORK_COVER / GEARNET_PDB_ROOT in gnet_all_prod.sh)
# export BASE_SPLIT_DIR="${WORK_COVER}/production_splitsv2"
# export OUTPUT_DIR="${WORK_COVER}/production_models_v2"

# Conda
export CONDA_SH="${HOME}/miniconda3/etc/profile.d/conda.sh"
export CONDA_ENV_GEARNET="gearnet"

# --- uplosd.sh (optional) ---
# export CONDA_ENV_UPLOAD="env_general"
# export HF_UPLOAD_FOLDER="/path/to/pdb_m15_ac"
# export HF_REPO_ID="your-org/your-dataset"
